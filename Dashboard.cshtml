@{
    ViewData["Title"] = "Dashboard";
    Layout = null; // Layout disable करो
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BankingPro - Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container-fluid py-5">
        <!-- BALANCE DISPLAY -->
        <div class="row text-center mb-5">
            <div class="col-12">
                <h1 class="display-3 fw-bold text-primary mb-3">🏦 BankingPro Dashboard</h1>
                <div class="h1 text-success fw-bold mb-2">₹@ViewBag.TotalBalance?.ToString("N0")</div>
                <div class="h4 text-muted">@ViewBag.AccountNumber</div>
            </div>
        </div>

        <!-- 4 MAIN SERVICES -->
        <div class="row g-4 mb-5">
            <div class="col-lg-3 col-md-6">
                <a asp-action="TransferMoney" class="text-decoration-none">
                    <div class="card border-0 shadow-lg h-100 p-4 text-center rounded-4 hover-card">
                        <i class="bi bi-arrow-left-right display-4 text-primary mb-3"></i>
                        <h4 class="fw-bold">💸 Money Transfer</h4>
                        <p class="text-muted mb-0">UPI • IMPS • NEFT</p>
                    </div>
                </a>
            </div>
            <div class="col-lg-3 col-md-6">
                <a asp-action="BillPayments" class="text-decoration-none">
                    <div class="card border-0 shadow-lg h-100 p-4 text-center rounded-4 hover-card">
                        <i class="bi bi-receipt-cutoff display-4 text-success mb-3"></i>
                        <h4 class="fw-bold">💰 Bill Payments</h4>
                        <p class="text-muted mb-0">All bills • Zero fee</p>
                    </div>
                </a>
            </div>
            <div class="col-lg-3 col-md-6">
                <a asp-action="ApplyLoan" class="text-decoration-none">
                    <div class="card border-0 shadow-lg h-100 p-4 text-center rounded-4 hover-card">
                        <i class="bi bi-cash-stack display-4 text-warning mb-3"></i>
                        <h4 class="fw-bold">💳 Personal Loan</h4>
                        <p class="text-muted mb-0">₹25 Lakhs • 9.99%</p>
                    </div>
                </a>
            </div>
            <div class="col-lg-3 col-md-6">
                <a asp-action="FixedDeposit" class="text-decoration-none">
                    <div class="card border-0 shadow-lg h-100 p-4 text-center rounded-4 hover-card">
                        <i class="bi bi-piggy-bank display-4 text-info mb-3"></i>
                        <h4 class="fw-bold">🏦 Fixed Deposit</h4>
                        <p class="text-muted mb-0">7.5% p.a. Interest</p>
                    </div>
                </a>
            </div>
        </div>

        <!-- MORE SERVICES -->
        <div class="row g-3 mb-5">
            <div class="col-lg-2 col-md-3 col-sm-4">
                <a asp-action="CreditCards" class="btn btn-outline-danger w-100 service-btn">
                    <i class="bi bi-credit-card me-2"></i>Credit Cards
                </a>
            </div>
            <div class="col-lg-2 col-md-3 col-sm-4">
                <a asp-action="AccountStatement" class="btn btn-outline-secondary w-100 service-btn">
                    <i class="bi bi-file-earmark-text me-2"></i>Statement
                </a>
            </div>
            <div class="col-lg-2 col-md-3 col-sm-4">
                <a asp-action="BalanceEnquiry" class="btn btn-outline-primary w-100 service-btn">
                    <i class="bi bi-wallet2 me-2"></i>Balance
                </a>
            </div>
            <div class="col-lg-2 col-md-3 col-sm-4">
                <a asp-action="Insurance" class="btn btn-outline-success w-100 service-btn">
                    <i class="bi bi-shield-check me-2"></i>Insurance
                </a>
            </div>
            <div class="col-lg-2 col-md-3 col-sm-4">
                <a asp-action="UpiQr" class="btn btn-outline-info w-100 service-btn">
                    <i class="bi bi-qr-code me-2"></i>UPI QR
                </a>
            </div>
            <div class="col-lg-2 col-md-3 col-sm-4">
                <a asp-action="Profile" class="btn btn-outline-warning w-100 service-btn">
                    <i class="bi bi-person-gear me-2"></i>Profile
                </a>
            </div>
        </div>

        <!-- QUICK ACTIONS -->
        <div class="row">
            <div class="col-md-3">
                <a asp-action="Logout" class="btn btn-secondary btn-lg w-100">
                    <i class="bi bi-box-arrow-right me-2"></i>Logout
                </a>
            </div>
        </div>
    </div>

    <style>
        .hover-card {
            transition: all 0.3s ease;
        }

            .hover-card:hover {
                transform: translateY(-10px);
                box-shadow: 0 20px 40px rgba(0,0,0,0.15) !important;
            }

        .service-btn {
            padding: 15px 10px;
            border-radius: 12px;
            font-size: 14px;
            transition: all 0.3s ease;
        }

            .service-btn:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 25px rgba(0,0,0,0.15);
            }
    </style>
</body>
</html>
